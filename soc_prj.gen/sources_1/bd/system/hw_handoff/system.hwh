                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="RESET">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Reset.&#xA;  When this bit is set to 1, the transmitter is reset. The bit then automatically reverts to 0. This reset also sets all of the transmitter configuration registers to their default values.&#xA;"/>
