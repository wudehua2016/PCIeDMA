            <REGISTER NAME="RX_CONF_WORD_0_REG">
              <PROPERTY NAME="DESCRIPTION" VALUE="Pause frame MAC Source Address[31:0]"/>
              <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0x400"/>
              <PROPERTY NAME="SIZE" VALUE="32"/>
              <PROPERTY NAME="ACCESS" VALUE="read-write"/>
              <PROPERTY NAME="IS_ENABLED" VALUE="true"/>
              <PROPERTY NAME="RESET_VALUE" VALUE="0xFFFFFFFF"/>
              <FIELDS>
                <FIELD NAME="RX_CONF_WORD_0">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Pause frame MAC Source Address[31:0].&#xA;  The address is ordered so the first byte transmitted/received is the lowest positioned byte in the register; for example, a MAC address of AA-BB-CC-DD-EE-FF would be stored in Address[47:0] as 0xFFEEDDCCBBAA.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="0"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="32"/>
                </FIELD>
              </FIELDS>
            </REGISTER>
            <REGISTER NAME="RX_CONF_WORD_1_REG">
              <PROPERTY NAME="DESCRIPTION" VALUE="Receiver Configuration Word 1"/>
              <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0x404"/>
              <PROPERTY NAME="SIZE" VALUE="32"/>
              <PROPERTY NAME="ACCESS" VALUE="read-write"/>
              <PROPERTY NAME="IS_ENABLED" VALUE="true"/>
              <PROPERTY NAME="RESET_VALUE" VALUE="0x1000FFFF"/>
              <FIELDS>
                <FIELD NAME="PAUSE_FRM_MAC_SA">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Pause frame MAC Source Address[47:32].&#xA;  Refer the RX_CONF_WORD_0 register description.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="0"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="16"/>
                </FIELD>
                <FIELD NAME="CTL_FRM_LEN_CHK_DISABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Control Frame Length Check Disable.&#xA;  When this bit is set to 1, the core does not mark control frames as bad if they are greater than the minimum frame length.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="24"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="24"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="LT_ERR_CHK_DISABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Length/Type Error Check Disable.&#xA;  1 - Core does not perform the length/type field error checks.&#xA;  0 - Core performs the length/type field error checks. Normal operation.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="25"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="25"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="HALF_DUPLEX">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Half Duplex.&#xA;  1 - Half Duplex.&#xA;  0 - Full Duplex.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="26"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="26"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="VLAN_ENABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="VLAN Enable.&#xA;  When this bit is set to 1, VLAN tagged frames are accepted by the receiver.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="27"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="27"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="RX_ENABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Receiver Enable.&#xA;  If set to 1, the receiver block is operational. If set to 0, the block ignores activity on the physical interface RX port.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="28"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="28"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="INBAND_FCS_ENBALE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="In-band FCS Enable.&#xA;  1 - MAC receiver passes the FCS field up to the client.&#xA;  0 - Client is not passed to the FCS.&#xA;In both cases, the FCS is verified on the frame.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="29"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="29"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="JUMBO_FRAME_ENBALE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Jumbo Frame Enable.&#xA;  1 - MAC receiver accepts frames over the specified IEEE 802.3-2008 maximum legal length.&#xA;  0 - MAC only accepts frames up to the specified maximum.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="30"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="30"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="RESET">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Reset.&#xA;  When this bit is set to 1, the receiver is reset. The bit then automatically reverts to 0. This reset also sets all of the receiver configuration registers to their default values.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="31"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="31"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
              </FIELDS>
            </REGISTER>
            <REGISTER NAME="TX_CONF_WORD_0_REG">
              <PROPERTY NAME="DESCRIPTION" VALUE="Transmitter Configuration Word"/>
              <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0x408"/>
              <PROPERTY NAME="SIZE" VALUE="32"/>
              <PROPERTY NAME="ACCESS" VALUE="read-write"/>
              <PROPERTY NAME="IS_ENABLED" VALUE="true"/>
              <PROPERTY NAME="RESET_VALUE" VALUE="0x10000000"/>
              <FIELDS>
                <FIELD NAME="IFG_ADJUST_ENABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Interframe Gap Adjust Enable.&#xA;  If 1, the transmitter reads the value on the port tx_ifg_delay at the start of frame transmission and adjusts the interframe gap following the frame accordingly. If 0, the transmitter outputs a minimum interframe gap of at least twelve clock cycles, as specified in IEEE 802.3-2008.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="25"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="25"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="HALF_DUPLEX">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Half Duplex.&#xA;  1 - Half Duplex.&#xA;  0 - Full Duplex.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="26"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="26"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="VLAN_ENABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="VLAN Enable.&#xA;  When this bit is set to 1, the transmitter recognizes the transmission of VLAN tagged frames.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="27"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="27"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="TX_ENABLE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Transmit Enable.&#xA;  1 - Transmitter is operational.&#xA;  0 - Transmitter is disabled.&#xA;"/>
                  <PROPERTY NAME="ADDRESS_OFFSET" VALUE="28"/>
                  <PROPERTY NAME="ACCESS" VALUE="read-write"/>
                  <PROPERTY NAME="MODIFIED_READ_VALUES" VALUE=""/>
                  <PROPERTY NAME="WRITE_CONSTRAINT" VALUE="0"/>
                  <PROPERTY NAME="READ_ACTION" VALUE=""/>
                  <PROPERTY NAME="BIT_OFFSET" VALUE="28"/>
                  <PROPERTY NAME="BIT_WIDTH" VALUE="1"/>
                </FIELD>
                <FIELD NAME="INBAND_FCS_ENBALE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="In-band FCS Enable.&#xA;  1 - MAC transmitter expects the FCS field to be passed in by the client.&#xA;  0 - MAC transmitter appends padding as required, computes the FCS and appends it to the frame.&#xA;"/>
