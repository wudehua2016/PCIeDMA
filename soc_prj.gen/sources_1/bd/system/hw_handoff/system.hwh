              <FIELDS>
                <FIELD NAME="PER_QUANTA_VALUE">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Pause Quanta 0 value.&#xA;  This register is only present when PFC is enabled at core customization time. When enabled, this register sets the quanta value to be inserted in the PFC frame for this priority.&#xA;"/>
