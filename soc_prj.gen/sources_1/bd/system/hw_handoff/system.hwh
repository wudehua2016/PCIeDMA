                <FIELD NAME="UNICAST_ADDRESS">
                  <PROPERTY NAME="DESCRIPTION" VALUE="Frame filter unicast address[47:32].&#xA;  See description for UNICAST_ADDRESS_WORD_0_REG.&#xA;"/>
