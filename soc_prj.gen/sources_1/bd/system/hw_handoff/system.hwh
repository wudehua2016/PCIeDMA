            <REGISTER NAME="TX_TIMESTAMP_ADJUST_CONTROL_REG">
              <PROPERTY NAME="DESCRIPTION" VALUE="Transmitter Timestamp Adjust Control Register"/>
              <PROPERTY NAME="ADDRESS_OFFSET" VALUE="0x41C"/>
              <PROPERTY NAME="SIZE" VALUE="32"/>
